-- teleport ไปเหนือมอน เหมือน EduHub u69
local function tpToMob(mob, range)
    local char = getChar()
    if not char or not mob or not mob.PrimaryPart then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local stand = char:FindFirstChild("Stand") and char.Stand:FindFirstChild("HumanoidRootPart")
    if hrp then
        pcall(function()
            local cf = mob.PrimaryPart.CFrame * CFrame.new(0, range, 0) * CFrame.Angles(math.rad(-90), 0, 0)
            hrp.CFrame = cf
            hrp.Velocity = Vector3.zero
            if stand then stand.CFrame = cf; stand.Velocity = Vector3.zero end
        end)
    end
end

local farmHeartbeat = nil

local function genericFarmLoop(questData)
    if farmHeartbeat then farmHeartbeat:Disconnect() end

    local qd = QUEST_DATA[questData.QuestText]
    if not qd then return end

    -- เทเลไปจุดเกิดมอนทันที (เหมือน EduHub)
    local char = getChar()
    if char then
        pcall(function() char.HumanoidRootPart.CFrame = qd.loadCFrame end)
    end

    local loaded = false
    local lastQuestTick = 0

    farmHeartbeat = game:GetService("RunService").Heartbeat:Connect(function()
        if not (isQuest or isAllLevel) then
            farmHeartbeat:Disconnect()
            farmHeartbeat = nil
            return
        end

        char = getChar()
        if not char then return end

        -- โหลด CFrame ครั้งแรกเท่านั้น (เหมือน EduHub u70)
        if not loaded then
            pcall(function() char.HumanoidRootPart.CFrame = qd.loadCFrame end)
            loaded = true
        end

        -- fire Done/QuestDone ทุก 0.2 วิ (เหมือน EduHub u72)
        local now = tick()
        if now - lastQuestTick >= 0.2 then
            lastQuestTick = now
            -- รับเควส (เหมือน EduHub u85)
            if questData.QuestText == "Bad Gi [Lvl. 1+]" or questData.QuestText == "Jungle Bandit [Lvl. 175+]" then
                local npc = findGiornoNPC(questData.QuestText)
                if npc then
                    pcall(function() npc.Done:FireServer() end)
                    pcall(function() npc.QuestDone:FireServer() end)
                end
            else
                for _, npc in ipairs(Services.Workspace.Map.NPCs:GetChildren()) do
                    if npc.Name == qd.npcName then
                        pcall(function() npc.Done:FireServer() end)
                        pcall(function() npc.QuestDone:FireServer() end)
                        break
                    end
                end
            end
        end

        -- หามอน
        local mob = findMob(qd.mobName)
        if mob then
            tpToMob(mob, qd.range)
            if char:FindFirstChild("Aura") and not char.Aura.Value then
                pcall(function() fire(char.StandEvents.Summon) end)
            end
            useSkills(char, selectedSkills, useAllSkills)
        else
            -- มอนตาย → วาปขึ้นฟ้าให้มอนเกิดเร็ว (เหมือน EduHub)
            char.Humanoid.Sit = false
            pcall(function()
                char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame + Vector3.new(0, 100, 0)
            end)
        end
    end)
end

