-- ==============================
local TabDungeon = Window:CreateTab("Dungeon", 4483362458)

local dNames = {}
for _, d in ipairs(CONFIG.Dungeons) do table.insert(dNames, d.Name) end

TabDungeon:CreateDropdown({
    Name = "Select Dungeon",
    Options = dNames,
    CurrentOption = {dNames[1]},
    MultipleOptions = false,
    Callback = function(v) selectedDungeon = v[1] or v end
})

TabDungeon:CreateToggle({
    Name = "Start Farm",
    CurrentValue = false,
    Callback = function(v)
        isDungeon = v
        if v then
            if isQuest or isAllLevel then
                notify("Error", "ปิดฟาร์มอื่นก่อนสิ!")
                isDungeon = false; return
            end
            farmThreads.dungeon = task.spawn(function()
                local dungeonData
                for _, d in ipairs(CONFIG.Dungeons) do
                    if d.Name == selectedDungeon then dungeonData = d; break end
                end
                if not dungeonData then return end
                local npc = findNPC("i_stabman", dungeonData.NpcText)
                while isDungeon do
                    local char = getChar()
                    if not char then task.wait(1); continue end
                    local questGui = LocalPlayer.PlayerGui:FindFirstChild("QuestGui")
                    if questGui and questGui:FindFirstChild("Active") and questGui.Active.Value then
                        local boss = findMob(dungeonData.BossName)
                        if boss then
                            local root = boss:FindFirstChild("HumanoidRootPart") or boss.PrimaryPart
                            if root then
                                tp(root.CFrame * CFrame.new(0,15,0) * CFrame.Angles(math.rad(-90),0,0))
                                if char:FindFirstChild("Aura") and not char.Aura.Value then fire(char.StandEvents.Summon) end
                                useSkills(char, selectedSkills, useAllSkills)
                            end
                        else
                            task.wait(1)
                        end
                    else
                        if npc then
                            tp(npc.HumanoidRootPart.CFrame * CFrame.new(0,2,3))
                            local pp = npc:FindFirstChildOfClass("ProximityPrompt")
                            if pp then fireproximityprompt(pp, 20) end
                            if npc:FindFirstChild("Done") then fire(npc.Done) end
                            task.wait(2)
                        end
                    end
                    task.wait()
                end
            end)
        else
            if farmThreads.dungeon then task.cancel(farmThreads.dungeon) end
            standUp()
        end
    end
})

