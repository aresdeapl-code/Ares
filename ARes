local LocalPlayer = Services.Players.LocalPlayer

function getChar()
    local char = LocalPlayer.Character
    if char and char:WaitForChild("HumanoidRootPart",2) and char:WaitForChild("Humanoid",2) then
        return char
    end
    return nil
end

function fire(remote, ...)
    if remote and remote:IsA("RemoteEvent") then
        local args = {...}
        pcall(function() remote:FireServer(table.unpack(args)) end)
    end
end

function tp(cf)
    local char = getChar()
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local stand = char:FindFirstChild("Stand") and char.Stand:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = cf
        hrp.Velocity = Vector3.zero
        if stand then stand.CFrame = cf; stand.Velocity = Vector3.zero end
    end
end

function findNPC(name, text)
    for _, npc in ipairs(Services.Workspace.Map.NPCs:GetChildren()) do
        if npc.Name == name then
            if text then
                local head = npc:FindFirstChild("Head")
                if head then
                    local main = head:FindFirstChild("Main") or head:FindFirstChild("Display")
                    if main then
                        local txt = main:FindFirstChild("Text") or (main:FindFirstChild("Frame") and main.Frame:FindFirstChild("TextLabel"))
                        if txt and txt.Text == text then return npc end
                    end
                end
            else
                return npc
            end
        end
    end
    return nil
end

function findMob(name)
    for _, mob in ipairs(Services.Workspace.Living:GetChildren()) do
        if mob.Name == name and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
            return mob
        end
    end
    return nil
end

function standUp()
    local char = getChar()
    if char then char.Humanoid.Sit = false end
end

function useSkills(char, skillNames, useAll)
    if not char or not char:FindFirstChild("StandEvents") then return end
    local events = char.StandEvents
    if useAll then
        for _, ev in ipairs(events:GetChildren()) do
            if ev:IsA("RemoteEvent") and not table.find({"Block","Quote","Pose","Summon","Heal","Jump","TogglePilot"}, ev.Name) then
                fire(ev, true)
            end
        end
    else
        for name, _ in pairs(skillNames) do
            local ev = events:FindFirstChild(name)
            if ev then fire(ev, true) end
        end
    end
end

function useItem(itemName)
    local char = getChar()
    if not char then return false end
    local tool = LocalPlayer.Backpack:FindFirstChild(itemName)
    if not tool then return false end
    char.Humanoid:UnequipTools()
    task.wait(0.2)
    char.Humanoid:EquipTool(tool)
    task.wait(1)
    local item = char:FindFirstChild(itemName)
    if not item then return false end
    pcall(function() item:Activate() end)
    task.wait(1)
    local pp = item:FindFirstChildOfClass("ProximityPrompt")
    if pp then pcall(function() fireproximityprompt(pp, 1) end) end
    task.wait(0.3)
    char.Humanoid:UnequipTools()
    return true
end

function switchStandToEmptySlot()
    local data = LocalPlayer.Data
    if not data then return false end
    local level = data.Level.Value
    local slots = {1,2,4}
    if level >= 120 then table.insert(slots, 3) end
    pcall(function()
        if Services.MarketplaceService:UserOwnsGamePassAsync(LocalPlayer.UserId, 142794026) then
            table.insert(slots, 3)
        end
    end)
    pcall(function()
        if Services.MarketplaceService:UserOwnsGamePassAsync(LocalPlayer.UserId, 146346514) then
            table.insert(slots, 5)
        end
    end)
    for _, slot in ipairs(slots) do
        local slotData = data["Slot"..slot.."Stand"]
        if slotData and slotData.Value == "None" then
            fire(Services.ReplicatedStorage.Events.SwitchStand, "Slot"..slot)
            task.wait(1)
            if data.Stand.Value == "None" then return true end
        end
    end
    return false
end

