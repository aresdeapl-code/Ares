local TabItems = Window:CreateTab("Items", 4483362458)

TabItems:CreateToggle({
    Name = "Farm Items",
    CurrentValue = false,
    Callback = function(v)
        isItems = v
        if v then
            if isQuest or isAllLevel or isBoss or isDungeon then
                notify("Error", "ปิดฟาร์มอื่นก่อน!")
                isItems = false; return
            end
            farmThreads.items = task.spawn(function()
                while isItems do
                    local char = getChar()
                    if not char then task.wait(1); continue end
                    local hrp = char.HumanoidRootPart
                    for _, obj in ipairs(Services.Workspace.Vfx:GetDescendants()) do
                        if obj:IsA("BasePart") and (obj.Name == "Handle" or obj.Name:find("Item")) and obj.Parent then
                            local pp = obj.Parent:FindFirstChild("ProximityPrompt") or obj:FindFirstChild("ProximityPrompt")
                            if pp then
                                local mag = (hrp.Position - obj.Position).Magnitude
                                if mag > 5 then
                                    pcall(function() hrp.CFrame = CFrame.new(obj.Position + Vector3.new(0,3,0)) end)
                                    task.wait(0.5)
                                end
                                if (hrp.Position - obj.Position).Magnitude <= 5 then
                                    fireproximityprompt(pp, 20)
                                    task.wait(0.3)
                                end
                            end
                        end
                    end
                    local itemsFolder = Services.Workspace:FindFirstChild("Items")
                    if itemsFolder then
                        for _, obj in ipairs(itemsFolder:GetChildren()) do
                            if obj:IsA("BasePart") and obj:FindFirstChild("ProximityPrompt") then
                                local mag = (hrp.Position - obj.Position).Magnitude
                                if mag > 5 then
                                    pcall(function() hrp.CFrame = CFrame.new(obj.Position + Vector3.new(0,3,0)) end)
                                    task.wait(0.5)
                                end
                                if (hrp.Position - obj.Position).Magnitude <= 5 then
                                    fireproximityprompt(obj.ProximityPrompt, 20)
                                    task.wait(0.3)
                                end
                            end
                        end
                    end
                    task.wait(0.5)
                end
            end)
        else
            if farmThreads.items then task.cancel(farmThreads.items) end
            standUp()
        end
    end
})

