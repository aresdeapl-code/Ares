-- ==============================
--   Refresh Skills (แก้ใหม่)
--   Rayfield ใช้ :Set() แทน SetValues
--   สร้าง dropdown ก่อน เก็บ ref แล้ว refresh ทีหลัง
-- ==============================
local skillDropdown = TabSettings:CreateDropdown({
    Name = "Select Skills",
    Options = {},
    CurrentOption = {},
    MultipleOptions = true,
    Callback = function(v)
        selectedSkills = {}
        for _, s in ipairs(v) do selectedSkills[s] = true end
    end
})

TabSettings:CreateButton({
    Name = "Refresh Skill List",
    Callback = function()
        local char = getChar()
        if not char or not char:FindFirstChild("StandEvents") then
            notify("Skills", "เรียกสแตนด์ก่อนแล้วกดใหม่")
            return
        end
        local list = {}
        for _, ev in ipairs(char.StandEvents:GetChildren()) do
            if ev:IsA("RemoteEvent") and not table.find(
                {"Block","Quote","Pose","Summon","Heal","Jump","TogglePilot"}, ev.Name
            ) then
                table.insert(list, ev.Name)
            end
        end
        -- อัปเดต options ใน dropdown โดยไม่ select ให้
        pcall(function() skillDropdown:Set(list) end)
        pcall(function() skillDropdown:Refresh(list, false) end)
        notify("Skills", "Refresh แล้ว: "..#list.." skills — เลือกเองใน Select Skills")
    end
})

