                local CONFIRM_ATTRS = {
                    "Daemon","Invincible","Tragic","Glass Cannon",
                    "Hacker","Legendary","Ascended","Buns","Helpful"
                }

                local function waitUntilStand(cond, timeout)
                    local t = 0
                    repeat task.wait(0.3); t += 0.3 until cond() or t >= (timeout or 6)
                end

                local function needsConfirm(attr)
                    for _, a in ipairs(CONFIRM_ATTRS) do
                        if a == attr then return true end
                    end
                    return false
                end

                local function handleConfirmDialog()
                    local btn = nil
                    local waited = 0
                    repeat
                        task.wait(0.2)
                        waited += 0.2
                        for _, gui in ipairs(LocalPlayer.PlayerGui:GetChildren()) do
                            if gui:IsA("ScreenGui") then
                                for _, obj in ipairs(gui:GetDescendants()) do
                                    if obj:IsA("TextButton") then
                                        local txt = obj.Text:lower()
                                        if txt == "yes" or txt == "confirm" or txt == "ยืนยัน" then
                                            btn = obj
                                        end
                                    end
                                end
                            end
                        end
                    until btn ~= nil or waited >= 4

                    if not btn then return end
                    task.wait(2.5)
                    pcall(function() btn.MouseButton1Click:Fire() end)
                    task.wait(0.5)
                end

                while isStand do
                    task.wait(0.3)
                    local char = getChar()
                    if not char then task.wait(1); continue end

                    local curStand = data.Stand.Value
                    local curAttr  = data.Attri.Value

                    if curStand ~= "None" then
                        local wantedStand = #selectedStands == 0
                        for _, name in ipairs(selectedStands) do
                            if CONFIG.StandValues[name] == curStand then wantedStand = true; break end
                        end
                        local wantedAttr = #selectedAttrs == 0
                        for _, attr in ipairs(selectedAttrs) do
                            if attr == curAttr then wantedAttr = true; break end
                        end

                        if wantedStand and wantedAttr then
                            notify("Got It!", "ได้แล้ว: "..curStand.." ("..curAttr..")")
                            isStand = false; return
                        end

                        local roka = useItem("Rokakaka")
                        if not roka then
                            if not switchStandToEmptySlot() then
                                notify("Error", "ไม่มี Rokakaka หรือ Slot ว่าง!")
                                isStand = false; return
                            end
                        end

                        if needsConfirm(curAttr) then
                            handleConfirmDialog()
                        end

                        waitUntilStand(function() return data.Stand.Value == "None" end, 8)
                        if data.Stand.Value ~= "None" then
                            local btn2 = nil
                            for _, gui in ipairs(LocalPlayer.PlayerGui:GetChildren()) do
                                if gui:IsA("ScreenGui") then
                                    for _, obj in ipairs(gui:GetDescendants()) do
                                        if obj:IsA("TextButton") and obj.Text:lower() == "yes" then
                                            btn2 = obj
                                        end
                                    end
                                end
                            end
                            if btn2 then pcall(function() btn2.MouseButton1Click:Fire() end) end
                            task.wait(1); continue
                        end
                    end

                    if not useItem(selectedItem) then
                        notify("Warning", "ไม่มี "..selectedItem.." ในกระเป๋า! รอ 5 วิ...")
                        task.wait(5); continue
                    end

                    waitUntilStand(function() return data.Stand.Value ~= "None" end, 6)
                end
            end)
        else
            if farmThreads.stand then task.cancel(farmThreads.stand) end
        end
    end
})

